# Public, browser-safe environment variables.
#
# IMPORTANT: Only variables prefixed with VITE_ are exposed to the browser.
# NEVER put your Gemini or SAM.gov API key here — those are server-side
# secrets and belong in `supabase secrets set` instead.
#
# Copy this file to `.env.local` and fill in real values.

# ── Supabase (safe to expose — RLS policies protect your data) ────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Optional overrides ────────────────────────────────────────────────

# Force demo mode (returns sample data instead of calling Edge Functions).
# Defaults to true when SUPABASE_URL or ANON_KEY are missing.
# VITE_DEMO_MODE=false

# Override the Edge Function base URL (defaults to ${VITE_SUPABASE_URL}/functions/v1).
# Useful when running `supabase functions serve` locally on a different port.
# VITE_FUNCTIONS_BASE_URL=http://localhost:54321/functions/v1

# ──────────────────────────────────────────────────────────────────────
# Server-side secrets — DO NOT put these here.
# Set them with the Supabase CLI:
#
#   supabase secrets set GEMINI_API_KEY=AIzaSy...
#   supabase secrets set SAM_GOV_API_KEY=your-key
#   supabase secrets set CORS_ALLOW_ORIGIN=https://yourapp.com
#
# These become Deno.env.get(...) inside Edge Functions and are never
# readable from the browser.
# ──────────────────────────────────────────────────────────────────────
